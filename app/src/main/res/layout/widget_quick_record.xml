<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="极速记账"
        android:textColor="#1B4D6B"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:weightSum="3">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <Button
                android:id="@+id/widget_btn_food"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/widget_button_bg"
                android:text="🍔\n餐饮"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <Button
                android:id="@+id/widget_btn_shopping"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/widget_button_bg"
                android:text="🛒\n购物"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <Button
                android:id="@+id/widget_btn_transport"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/widget_button_bg"
                android:text="🚗\n交通"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:weightSum="3">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <Button
                android:id="@+id/widget_btn_entertainment"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/widget_button_bg"
                android:text="🎮\n娱乐"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <Button
                android:id="@+id/widget_btn_housing"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/widget_button_bg"
                android:text="🏠\n住房"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <Button
                android:id="@+id/widget_btn_more"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/widget_button_bg"
                android:text="➕\n更多"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
